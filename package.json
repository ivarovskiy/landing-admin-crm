{
  "name": "landing-admin-crm",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "packageManager": "pnpm@9.15.5",
  "scripts": {
    "dev:api": "pnpm -C apps/api start:dev",
    "dev:admin": "pnpm -C apps/admin dev",
    "dev:web": "pnpm -C apps/web dev",
    "gen:openapi": "pnpm -C packages/openapi-client gen",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "wait:api": "wait-on tcp:3000",
    "wait:admin": "wait-on tcp:3001",
    "dev": "concurrently -k -n api,admin,web \"pnpm -C apps/api dev\" \"pnpm wait:api && pnpm -C apps/admin dev\" \"pnpm wait:admin && pnpm -C apps/web dev\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "turbo": "^2.8.11",
    "typescript": "^5.9.3"
  }
}